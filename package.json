{
  "name": "it-ticket-system",
  "version": "2.0.0",
  "description": "Professional IT Help Desk Ticket System with SLA, AD Sync, Role-based Access",
  "main": "src/electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run server\" \"npm run frontend\"",
    "server": "node src/backend/server.js",
    "frontend": "vite",
    "build": "vite build",
    "build:exe": "vite build && electron-builder --win --x64 --dir",
    "package": "vite build && powershell -ExecutionPolicy Bypass -File scripts/package-exe.ps1",
    "lint": "eslint src --ext .js,.jsx"
  },
  "dependencies": {
    "activedirectory2": "^2.2.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.10",
    "socket.io": "^4.7.4",
    "sql.js": "^1.10.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2",
    "eslint": "^8.56.0",
    "vite": "^5.0.10"
  },
  "build": {
    "appId": "com.itticketsystem.pro",
    "productName": "IT Ticket System Pro",
    "asar": false,
    "win": {
      "target": "dir"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IT Ticket System Pro"
    },
    "files": [
      "dist/**/*",
      "src/backend/**/*",
      "src/electron/**/*",
      "data/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    }
  }
}
