{
  "name": "it-ticket-system",
  "version": "2.0.0",
  "description": "Professional IT Help Desk Ticket System with SLA, AD Sync, Role-based Access",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run frontend\"",
    "prod": "npm run build && npm run server",
    "server": "node src/backend/server.js",
    "frontend": "vite",
    "build": "vite build",
    "lint": "eslint src --ext .js,.jsx"
  },
  "dependencies": {
    "activedirectory2": "^2.2.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.10",
    "socket.io": "^4.7.4",
    "sql.js": "^1.10.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "vite": "^5.0.10"
  }
