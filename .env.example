# IT Ticket System - Configuration
# Copy this file to .env and customize

# Server
PORT=3000
JWT_SECRET=change-this-to-a-random-secret-key
JWT_EXPIRY=24h

# Database
DB_PATH=data/tickets.db
UPLOAD_DIR=data/uploads
LOG_DIR=data/logs

# Maintenance Mode (true/false)
MAINTENANCE_MODE=false

# Active Directory (optional)
AD_ENABLED=false
AD_URL=ldap://domain.local
AD_BASE_DN=DC=domain,DC=local
AD_USERNAME=
AD_PASSWORD=
AD_SYNC_INTERVAL=3600000

# SMTP Email (optional)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ticket-system.local
